# cube_outline.obj (fake triangulated for cube outline)

v -0.5 -0.5 -0.5  # 1
v  0.5 -0.5 -0.5  # 2
v  0.5  0.5 -0.5  # 3
v -0.5  0.5 -0.5  # 4
v -0.5 -0.5  0.5  # 5
v  0.5 -0.5  0.5  # 6
v  0.5  0.5  0.5  # 7
v -0.5  0.5  0.5  # 8

# Bottom face (Outline)
f 1 2 2
f 2 3 3
f 3 4 4
f 4 1 1

# Top face (Outline)
f 5 6 6
f 6 7 7
f 7 8 8
f 8 5 5

# Front face (Outline)
f 1 2 2
f 2 6 6
f 6 5 5
f 5 1 1

# Back face (Outline)
f 4 3 3
f 3 7 7
f 7 8 8
f 8 4 4

# Left face (Outline)
f 1 4 4
f 4 8 8
f 8 5 5
f 5 1 1

# Right face (Outline)
f 2 3 3
f 3 7 7
f 7 6 6
